# Google OAuth 2.0 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=933568187035-q36oq51c47kaskugimat6fimecop33bm.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Cookie signing secret (generate a random string)
COOKIE_SECRET=change-me-to-a-random-string

# Server port
PORT=3000

# Environment
NODE_ENV=development

# Base path for subpath hosting (e.g. '/waymark' when served at swiftirons.com/waymark/)
# Leave empty or omit for running at root
# BASE_PATH=/waymark

# Set to "true" to enable local-only mode (mock data, no Google account needed)
# WAYMARK_LOCAL=true

# ── Plaid (bank account OAuth link flow) ──────────────────────────────────────
# Get credentials at https://dashboard.plaid.com/
# PLAID_CLIENT_ID=your-plaid-client-id
# PLAID_SECRET=your-plaid-secret
# PLAID_ENV=sandbox  # sandbox | development | production

# ── AI Agent Fleet ────────────────────────────────────────────────────────────
#
# These are read by `make up` to start the agent fleet.
# Edit here, then run `make up` — no other CLI flags needed.
#

# Space-separated names of agents to start (one container per name)
# Names appear in logs and in the Agent Registry UI
AGENT_NAMES=Alex

# AI provider: copilot | claude | auto (auto = detect from credentials)
PROVIDER=auto

# Copilot model (run `copilot --list-models` to see options)
MODEL=claude-sonnet-4.6

# Claude Code model (Anthropic model ID)
CLAUDE_MODEL=claude-opus-4-5

# Anthropic API key — required if PROVIDER=claude or PROVIDER=auto with no Copilot token
# ANTHROPIC_API_KEY=sk-ant-...

# Agent Registry Google Sheet ID — agents read tuning strings from this sheet on boot
# Create an "agents" template sheet in Waymark, then paste the sheet ID here
# AGENTS_SHEET_ID=

# Waymark workboard sheet ID — agents poll this for tasks
# WAYMARK_WORKBOARD_ID=

# Initial agent command (what the agent runs when it boots)
# COMMAND=@waymark-builder start

# Real-agent evals (comma or newline separated Gemini API keys; keep only in local .env)
# WAYMARK_AGENT_EVAL_KEYS=
# WAYMARK_AGENT_EVAL_MODEL=gemini-flash-latest
