<?xml version="1.0" encoding="utf-8"?>
<!-- AndroidManifest.xml — Waymark Android App -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for the web app and WebRTC signaling -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service for background WebRTC connection -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_REMOTE_MESSAGING" />

    <!-- WiFi lock — prevents the radio from sleeping mid-ICE while screen is off -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Vibration for notification feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Wake lock: keep CPU alive briefly to process incoming messages -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Restart the P2P service after device reboot or app update -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Ask the user to exempt Waymark from Doze battery optimizations so the
         foreground service retains network access during idle windows -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Waymark"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Handle OAuth deep-link redirect back to app -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.waymark.app" android:host="auth_success" />
                <data android:scheme="com.waymark.app" android:host="auth_error" />
            </intent-filter>
        </activity>

        <!-- Background WebRTC service for orchestrator P2P notifications -->
        <service
            android:name=".WebRtcService"
            android:foregroundServiceType="remoteMessaging"
            android:exported="false" />

        <!-- Restart WebRtcService after a device reboot or app update -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Debug/test helper: set or clear the AES signal key via adb broadcast.
             The AES key NEVER touches any Google Sheet - it is only distributed
             over the WebRTC DataChannel in production and via adb in test.
             Not exported - target with component name from adb:
               adb shell am broadcast -n com.waymark.app/.SignalKeyReceiver
                 -a com.waymark.app.action.SET_SIGNAL_KEY
                 -e signalKey HEX64_KEY -->
        <receiver
            android:name=".SignalKeyReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.waymark.app.action.SET_SIGNAL_KEY" />
                <action android:name="com.waymark.app.action.CLEAR_SIGNAL_KEY" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
