{
  "name": "waymark",
  "version": "1.0.0",
  "description": "Turn Google Sheets into interactive tools — two-way sync, zero server state",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "WAYMARK_LOCAL=true node server/index.js",
    "generate": "node scripts/generate-examples.js",
    "test": "WAYMARK_LOCAL=true npx playwright test --config tests/playwright.config.js",
    "test:changed": "WAYMARK_LOCAL=true node scripts/run-fast-tests.js",
    "test:changed:list": "WAYMARK_LOCAL=true node scripts/run-fast-tests.js --list",
    "test:unit": "WAYMARK_LOCAL=true npx playwright test --config tests/playwright.config.js --grep unit-",
    "test:e2e": "WAYMARK_LOCAL=true npx playwright test --config tests/playwright.config.js --ignore-pattern unit-*",
    "test:headed": "WAYMARK_LOCAL=true npx playwright test --config tests/playwright.config.js --headed",
    "test:debug": "WAYMARK_LOCAL=true npx playwright test --config tests/playwright.config.js --debug",
    "screenshots": "WAYMARK_LOCAL=true npx playwright test --config playwright.screenshots.config.js",
    "design-audit": "node scripts/design-audit.js",
    "design-review": "npm run screenshots && npm run design-audit",
    "build-info": "node scripts/build-info.js",
    "test:agent:live": "WAYMARK_LOCAL=true node scripts/run-agent-evals.js",
    "test:writer:eval": "WAYMARK_LOCAL=true node scripts/run-writer-evals.js",
    "test:report": "WAYMARK_LOCAL=true node scripts/generate-test-report.js",
    "test:report:upload": "WAYMARK_LOCAL=true node scripts/generate-test-report.js --upload"
  },
  "keywords": [
    "checklist",
    "google-sheets",
    "drive",
    "templates"
  ],
  "license": "GPL-3.0-only",
  "private": true,
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "js-yaml": "^4.1.1",
    "mqtt": "^5.15.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5"
  }
}
